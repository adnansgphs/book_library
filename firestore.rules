rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "adnan.sgphs@gmail.com" || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidBook(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && (!('author' in data) || (data.author is string && data.author.size() <= 200))
        && (!('isbn' in data) || (data.isbn is string && data.isbn.size() <= 50))
        && (!('coverUrl' in data) || (data.coverUrl is string && data.coverUrl.size() <= 1000))
        && (!('publisher' in data) || (data.publisher is string && data.publisher.size() <= 200))
        && (!('categories' in data) || (data.categories is list && data.categories.size() <= 20))
        && (!('pdfUrl' in data) || (data.pdfUrl is string && data.pdfUrl.size() <= 2000))
        && (!('directLink' in data) || (data.directLink is string && data.directLink.size() <= 2000))
        && (!('description' in data) || (data.description is string && data.description.size() <= 10000));
    }

    match /books/{bookId} {
      allow read: if true;
      
      allow create: if isAdmin() 
        && isValidId(bookId)
        && isValidBook(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time
        && incoming().createdBy == request.auth.uid;

      allow update: if isAdmin()
        && isValidBook(incoming())
        && incoming().updatedAt == request.time
        && incoming().createdAt == existing().createdAt
        && incoming().createdBy == existing().createdBy;

      allow delete: if isAdmin();
    }

    match /blogPosts/{postId} {
      allow read: if true;

      allow create: if isAdmin()
        && isValidId(postId)
        && incoming().title is string && incoming().title.size() <= 200
        && incoming().content is string && incoming().content.size() <= 50000
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      allow update: if isAdmin()
        && incoming().updatedAt == request.time
        && incoming().createdAt == existing().createdAt;

      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId)
        && isValidId(userId)
        && incoming().role == "user"
        && incoming().email == request.auth.token.email;

      allow update: if (isOwner(userId) && !incoming().diff(existing()).affectedKeys().hasAny(['role']))
        || isAdmin();
    }
  }
}
